{
  "name": "@fluent-kit/ui",
  "version": "0.1.0",
  "description": "React component library with Fluent/Windows-11 design — config-driven antd-shape API, ships compiled CSS (zero Tailwind config required).",
  "keywords": [
    "react",
    "component-library",
    "fluent",
    "windows-11",
    "antd",
    "datatable",
    "tailwind",
    "radix",
    "ui",
    "design-system"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tuwibu/fluentkit.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "files": [
    "dist",
    "!dist/**/*.map",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./rhf": {
      "import": {
        "types": "./dist/rhf/index.d.ts",
        "default": "./dist/rhf/index.js"
      },
      "require": {
        "types": "./dist/rhf/index.d.cts",
        "default": "./dist/rhf/index.cjs"
      }
    },
    "./styles.css": "./dist/styles.css"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "rhf": ["./dist/rhf/index.d.ts"]
    }
  },
  "scripts": {
    "build:css": "tailwindcss -i src/styles/index.css -o dist/styles.css --minify && node scripts/copy-fonts.mjs",
    "build": "tsup && pnpm run build:css",
    "smoke": "node scripts/import-smoke.mjs",
    "test": "vitest run",
    "test:types": "vitest --typecheck --run --config vitest.typecheck.config.ts",
    "test:watch": "vitest",
    "lint": "eslint src"
  },
  "peerDependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.68.0",
    "zod": "^3.24.0"
  },
  "peerDependenciesMeta": {
    "react-hook-form": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  },
  "devDependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@tailwindcss/cli": "^4.3.1",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.24",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "jsdom": "^26.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.68.0",
    "tailwindcss": "^4.1.10",
    "tsup": "^8.4.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.6.3",
    "vitest": "^3.2.6",
    "zod": "^3.24.0"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource/geist-mono": "^5.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.556.0",
    "radix-ui": "^1.4.3",
    "tailwind-merge": "^3.5.0"
  }
}
