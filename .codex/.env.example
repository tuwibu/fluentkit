# Codex CLI — Project Environment Variables
#
# SINGLE SOURCE OF TRUTH: copy this file → `.codex/.env` and fill in.
# That's the only env file you need to edit.
#
# (Resolver also supports `.agents/skills/.env` and `.agents/skills/<skill>/.env`
#  as optional overrides — not needed for normal use. Debug with:
#  python .codex/scripts/resolve_env.py --show-hierarchy)
#
# NOTE: Codex has NO env-file injection (CODEX_ENV_FILE does not exist). Python
# skills read this file directly via resolve_env.py — values do NOT auto-export
# to the shell. Keep keys in sync with `.claude/.env` (separate resolver tree).

# ============================================
# AI / LLM API Keys
# ============================================
# Google Gemini — ai-multimodal, docs-seeker, repomix
# Get: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# OpenRouter — optional fallback router for image gen / non-Google models
# Get: https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=

# MiniMax — optional image/video/speech/music generation
# Get: https://platform.minimax.io/user-center/basic-information/interface-key
# MINIMAX_API_KEY=

# Vertex AI — optional alternative to AI Studio
# GEMINI_USE_VERTEX=true
# VERTEX_PROJECT_ID=
# VERTEX_LOCATION=us-central1

# ============================================
# Docs & MCP
# ============================================
# Context7 — docs-seeker, use-mcp
# Get: https://context7.com/dashboard/api-keys
CONTEXT7_API_KEY=

# ============================================
# Notification Hooks
# ============================================
# Discord webhook — Server Settings → Integrations → Webhooks
DISCORD_WEBHOOK_URL=

# Telegram — @BotFather for token, /getUpdates for chat id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ============================================
# Database (shared across skills)
# ============================================
# DATABASE_URL=postgresql://user:pass@localhost:5432/db
# MONGODB_URI=mongodb://localhost:27017/db
# REDIS_URL=redis://localhost:6379

# ============================================
# Dev / CI
# ============================================
# NODE_ENV=development
# LOG_LEVEL=info
